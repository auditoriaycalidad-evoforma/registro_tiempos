generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model minuta_actividad {
  code                      String                      @id @db.VarChar(32)
  nombre                    String                      @db.VarChar(255)
  area                      String?                     @db.VarChar(32)
  descripcion               String?                     @db.VarChar(2048)
  minuta_area               minuta_area?                @relation(fields: [area], references: [code], onDelete: NoAction, onUpdate: NoAction, map: "fk_actividad_area")
  minuta_registro_actividad minuta_registro_actividad[]
}

model minuta_area {
  code             String             @id @db.VarChar(32)
  nombre           String             @db.VarChar(255)
  minuta_actividad minuta_actividad[]
}

model minuta_empleado {
  id                        String                      @id @db.VarChar(64)
  apellido_nombre           String                      @db.VarChar(255)
  cargo                     String?                     @db.VarChar(255)
  email                     String?                     @unique @db.VarChar(255)
  telefono                  String?                     @db.VarChar(50)
  es_lider                  String?                     @db.VarChar(1)
  hora_inicio_lv            DateTime?                   @db.Time(6)
  hora_fin_lv               DateTime?                   @db.Time(6)
  hora_inicio_sabado        DateTime?                   @db.Time(6)
  hora_fin_sabado           DateTime?                   @db.Time(6)
  minuta_registro_actividad minuta_registro_actividad[]
}

model minuta_proyecto {
  code                      String                      @id @db.VarChar(32)
  nombre                    String                      @db.VarChar(255)
  minuta_registro_actividad minuta_registro_actividad[]
}

model minuta_registro_actividad {
  id               Int               @id @default(autoincrement())
  empleado         String            @db.VarChar(64)
  fecha            DateTime          @db.Date
  hora_inicio      DateTime          @db.Time(6)
  hora_fin         DateTime          @db.Time(6)
  actividad        String?           @db.VarChar(32)
  proyecto         String?           @db.VarChar(32)
  tipo_minuta      String            @db.VarChar(1)
  aprobado         String?           @default("NO") @db.VarChar(2)
  observacion      String?           @db.VarChar(2048)
  minuta_actividad minuta_actividad? @relation(fields: [actividad], references: [code], onDelete: NoAction, onUpdate: NoAction, map: "fk_registro_actividad")
  minuta_empleado  minuta_empleado   @relation(fields: [empleado], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_registro_empleado")
  minuta_proyecto  minuta_proyecto?  @relation(fields: [proyecto], references: [code], onDelete: NoAction, onUpdate: NoAction, map: "fk_registro_proyecto")
}
